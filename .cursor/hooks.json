{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "node .cursor/hooks/session-init.js"
      }
    ],
    "preToolUse": [
      {
        "command": "node .cursor/hooks/ownership-guard.js",
        "matcher": "Write"
      }
    ],
    "stop": [
      {
        "command": "node .cursor/hooks/gate-runner.js"
      }
    ]
  }
}
